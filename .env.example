# Mark43 API — local dev only. Deployed envs use M43AUTH session cookie from auth-proxy.
MARK43_BASE_URL=m43formstest.qa
MARK43_FULL_BASE_URL=
MARK43_API_TOKEN=

# Base path — must match k8s VirtualService route prefix (e.g. /my-app/)
BASE_PATH=/

# Cache TTL in seconds
CACHE_TIMEOUT_SECONDS=300

# Server port
PORT=8080
